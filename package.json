{
  "name": "ai-usage-tracker",
  "version": "0.1.0",
  "description": "Scan local Claude Code token usage and submit it to a leaderboard backend.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "aiusage": "bin/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "install.sh"
  ],
  "scripts": {
    "scan": "node bin/cli.js scan",
    "submit": "node bin/cli.js submit --dry-run"
  },
  "keywords": ["claude", "claude-code", "llm", "tokens", "usage", "leaderboard"],
  "license": "MIT"
}
